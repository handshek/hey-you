{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "agent/Dockerfile.railway"
  },
  "deploy": {
    "startCommand": "python agent_yolo.py serve --host 0.0.0.0 --port $PORT --http-log-level info --agents-log-level info",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 600,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
