FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    YOLO_CONFIG_DIR=/tmp/Ultralytics \
    MALLOC_TRIM_THRESHOLD_=0 \
    OMP_NUM_THREADS=1 \
    MKL_NUM_THREADS=1 \
    OPENBLAS_NUM_THREADS=1 \
    YOLO_PROCESS_FPS=2 \
    YOLO_OUTPUT_FPS=2

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip

# Install CPU-only PyTorch first to avoid CUDA wheel downloads and huge image bloat.
RUN pip install --index-url https://download.pytorch.org/whl/cpu torch torchvision

RUN pip install "getstream[telemetry,webrtc]==2.7.1" \
    "vision-agents==0.3.7" \
    "vision-agents-plugins-elevenlabs==0.3.7" \
    "vision-agents-plugins-getstream==0.3.7" \
    "vision-agents-plugins-openai==0.3.8" \
    "vision-agents-plugins-openrouter==0.3.8" \
    "vision-agents-plugins-ultralytics==0.3.8" \
    python-dotenv

COPY agent/ /app/

CMD ["sh", "-c", "python agent_yolo.py serve --host 0.0.0.0 --port ${PORT:-8000}"]
